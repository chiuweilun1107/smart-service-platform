{
  "manifest_version": 3,
  "name": "智慧服務平台 AI 填表助手",
  "version": "1.0.0",
  "description": "AI 對話式表單填寫助手 — 智慧服務平台動物保護/市民服務通報",
  "permissions": [
    "sidePanel",
    "activeTab",
    "storage",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "http://127.0.0.1/*",
    "http://localhost/*",
    "https://chiuweilun1107.github.io/*",
    "https://*.openai.azure.com/*"
  ],
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": false
  },
  "content_scripts": [
    {
      "matches": [
        "http://127.0.0.1/*",
        "http://localhost/*",
        "https://chiuweilun1107.github.io/*"
      ],
      "js": [
        "content/form-detector.js",
        "content/form-filler.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "智慧服務平台 AI 填表助手"
  }
}
